'use client';

import { useState } from 'react';
import { Zap, CheckCircle, XCircle, AlertCircle } from 'lucide-react';

export default function SEOTool() {
  const [url, setUrl] = useState('');
  const [analyzing, setAnalyzing] = useState(false);
  const [result, setResult] = useState(null);
  
  const analyzeSite = async () => {
    setAnalyzing(true);
    // Simulate API call to your SEO tools
    setTimeout(() => {
      setResult({
        score: 78,
        issues: 3,
        warnings: 5,
        passed: 12
      });
      setAnalyzing(false);
    }, 2000);
  };
  
  return (
    <div className="card">
      <div className="flex items-center gap-2 mb-4">
        <Zap className="text-blue-600" />
        <h2 className="text-xl font-semibold">Quick SEO Audit</h2>
      </div>
      
      <input
        type="url"
        placeholder="Enter website URL to analyze"
        value={url}
        onChange={(e) => setUrl(e.target.value)}
        className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent mb-4"
      />
      
      <button
        onClick={analyzeSite}
        disabled={analyzing || !url}
        className="btn-primary w-full disabled:opacity-50"
      >
        {analyzing ? 'Analyzing...' : 'Run SEO Audit'}
      </button>
      
      {result && (
        <div className="mt-6 space-y-3">
          <div className="text-center">
            <div className="text-4xl font-bold text-blue-600">{result.score}</div>
            <div className="text-sm text-gray-600">SEO Score</div>
          </div>
          
          <div className="grid grid-cols-3 gap-2 text-center">
            <div>
              <div className="text-red-600 font-semibold">{result.issues}</div>
              <div className="text-xs text-gray-600">Issues</div>
            </div>
            <div>
              <div className="text-yellow-600 font-semibold">{result.warnings}</div>
              <div className="text-xs text-gray-600">Warnings</div>
            </div>
            <div>
              <div className="text-green-600 font-semibold">{result.passed}</div>
              <div className="text-xs text-gray-600">Passed</div>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
